# MySQL root password (used by Docker Compose to initialize the DB container)
MYSQL_ROOT_PASSWORD=changeme

# App database user (used by both Docker Compose and the Node service)
MYSQL_USER=appuser
MYSQL_PASSWORD=changeme

# Node service — DB connection (gen_params.js reads these)
DB_HOST=localhost
DB_USER=appuser
DB_PASSWORD=changeme
DB_NAME=blood_pressure_tracker

# Swagger UI server URL (shown in the API docs "Try it out" base URL)
SWAGGER_SERVER=http://localhost:7291

# Comma-separated list of allowed CORS origins (leave empty to deny all cross-origin requests)
ALLOWED_ORIGINS=
